# .env.example — copie para cloud/bridge/.env e preencha (o .env está no .gitignore).

# Broker MQTT (Mosquitto local em Docker)
MQTT_HOST=127.0.0.1
MQTT_PORT=8883
MQTT_USERNAME=tmt
MQTT_PASSWORD=tmt
MQTT_CAFILE=../broker/certs/ca.crt

# Supabase local (veja `supabase status`)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_KEY=COLE_A_SERVICE_ROLE_KEY_LOCAL_AQUI

# Telegram (crie o bot no @BotFather e pegue seu chat_id no @userinfobot)
TELEGRAM_BOT_TOKEN=COLE_O_TOKEN_DO_BOTFATHER
TELEGRAM_CHAT_ID=COLE_SEU_CHAT_ID

# Deve casar com HEARTBEAT_INTERVAL_S do firmware (config.h)
HEARTBEAT_INTERVAL_S=60
