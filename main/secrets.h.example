/*
 * secrets.h.example — modelo de credenciais sensíveis (NÃO versionar o secrets.h real).
 *
 * Copie este arquivo para main/secrets.h e preencha com os valores do seu ambiente:
 *
 *     cp main/secrets.h.example main/secrets.h
 *
 * O secrets.h está no .gitignore. Sem ele o build falha de propósito (força o
 * preenchimento das credenciais).
 */
#ifndef SECRETS_H
#define SECRETS_H

/* Wi-Fi (rede onde o ESP32 e o Mac que roda o broker estão juntos). */
#define WIFI_SSID   "SUA_REDE_WIFI"
#define WIFI_PASS   "SUA_SENHA_WIFI"

/* Broker MQTT (Mosquitto em Docker no Mac) — use o IP do Mac na LAN, não localhost. */
#define MQTT_HOST   "192.168.0.100"
#define MQTT_USER   "tmt"
#define MQTT_PASS   "tmt"

#endif /* SECRETS_H */
